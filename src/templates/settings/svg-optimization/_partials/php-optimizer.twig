{% import "_includes/forms" as forms %}

<p class="light" style="margin-top: 0; margin-bottom: 8px;">{{ 'These settings control which optimization rules are applied when using the PHP optimizer. The plugin now targets the php-svg-optimizer v8 rule set while keeping legacy behavior explicit.'|t('icon-manager') }}</p>
<p class="light" style="margin-bottom: 24px;">{{ 'For more information about each rule, see the'|t('icon-manager') }} <a href="https://github.com/MathiasReker/php-svg-optimizer" target="_blank" rel="noopener noreferrer">php-svg-optimizer documentation</a>.</p>

<hr>

<h2>{{ 'Risky Rules'|t('icon-manager') }}</h2>
<p class="light">{{ 'php-svg-optimizer v8 requires risky rules to be explicitly allowed. Keep this enabled to preserve pre-v8 behavior for risky removals such as width/height and enable-background.'|t('icon-manager') }}</p>

{{ forms.lightswitchField({
    label: 'Allow Risky Rules'|t('icon-manager'),
    instructions: 'Enable the risky optimizer rule group below. When disabled, risky rules are hidden and not applied.'|t('icon-manager'),
    id: 'optimizeAllowRiskyRules',
    name: 'settings[optimizeAllowRiskyRules]',
    on: settings.optimizeAllowRiskyRules,
    toggle: 'risky-rule-settings',
    warning: settings.isOverriddenByConfig('optimizeAllowRiskyRules') ? 'This is being overridden by the <code>optimizeAllowRiskyRules</code> setting in the <code>config/icon-manager.php</code> file.'|t('icon-manager')|raw : null,
    disabled: settings.isOverriddenByConfig('optimizeAllowRiskyRules')
}) }}

<div id="risky-rule-settings" class="{% if not settings.optimizeAllowRiskyRules %}hidden{% endif %}">
    <hr>

    <h2>{{ 'Risky Rule Group'|t('icon-manager') }}</h2>
    <p class="light">{{ 'These rules are only available when risky rules are enabled. They can change rendering or remove data used outside pure SVG presentation, so they are grouped here intentionally.'|t('icon-manager') }}</p>

    {{ forms.lightswitchField({
        label: 'Remove Data Attributes'|t('icon-manager'),
        instructions: 'Remove <code>data-*</code> attributes.'|t('icon-manager')|raw,
        id: 'optimizeRemoveDataAttributes',
        name: 'settings[optimizeRemoveDataAttributes]',
        on: settings.optimizeRemoveDataAttributes,
