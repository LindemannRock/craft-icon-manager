{% js %}
(() => {
    const riskySection = document.getElementById('risky-rule-settings');
    if (!riskySection) {
        return;
    }

    const field = document.getElementById('optimizeAllowRiskyRules-field');
    const lightswitch = field?.querySelector('.lightswitch');
    const hiddenInput = field?.querySelector('input[name="settings[optimizeAllowRiskyRules]"]');

    if (!lightswitch) {
        return;
    }

    const syncRiskySection = () => {
        const isOn = lightswitch.classList.contains('on')
            || lightswitch.getAttribute('aria-checked') === 'true'
            || hiddenInput?.value === '1';

        riskySection.classList.toggle('hidden', !isOn);
    };

    lightswitch.addEventListener('click', () => {
        window.setTimeout(syncRiskySection, 0);
    });

    lightswitch.addEventListener('change', syncRiskySection);
    syncRiskySection();
})();
{% endjs %}
